{
    "id": "opencode-cli",
    "version": "1.2.0",
    "name": "Opencode CLI",
    "documentationURL": "https://github.com/uabcodus/devcontainer-features/tree/master/src/opencode-cli",
    "description": "Installs Opencode CLI (opencode).",
    "options": {
        "version": {
            "type": "string",
            "proposals": [
                "latest"
            ],
            "default": "latest",
            "description": "Select or enter an opencode-cli version."
        }
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ],
    "mounts": [
        {
        "source": "${localEnv:HOME}/.config/opencode/opencode.jsonc",
        "target": "${containerUserHome}/.config/opencode/opencode.jsonc",
        "type": "bind"
        },
        {
        "source": "${localEnv:HOME}/.local/share/opencode/auth.json",
        "target": "${containerUserHome}/.local/share/opencode/auth.json",
        "type": "bind"
        }
    ]
}
